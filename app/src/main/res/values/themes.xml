<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.BuildX" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <!-- Surface colors. -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorBackgroundFloating">@color/background</item>
    </style>

    <!-- Editor theme with action bar -->
    <style name="Theme.BuildX.Editor" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <!-- AppBar overlay theme -->
    <style name="Theme.BuildX.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar" />

    <!-- Popup overlay theme -->
    <style name="Theme.BuildX.PopupOverlay" parent="ThemeOverlay.Material3.Dark" />

    <!-- Splash screen theme -->
    <style name="Theme.BuildX.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/primary_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.BuildX</item>
    </style>

    <!-- Dialog theme -->
    <style name="Theme.BuildX.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="android:windowMinWidthMajor">65%</item>
        <item name="android:windowMinWidthMinor">95%</item>
    </style>

    <!-- Bottom sheet style -->
    <style name="Theme.BuildX.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearance">?attr/shapeAppearanceCornerExtraLarge</item>
    </style>

    <!-- Card style -->
    <style name="Theme.BuildX.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="shapeAppearanceOverlay">?attr/shapeAppearanceCornerMedium</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- Button style -->
    <style name="Theme.BuildX.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearance">?attr/shapeAppearanceCornerSmall</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Text input style -->
    <style name="Theme.BuildX.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="shapeAppearance">?attr/shapeAppearanceCornerSmall</item>
    </style>

</resources>
